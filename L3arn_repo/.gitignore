.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
# Explicitly protect the local secrets file
apps/web/.env.local
services/ai-workers/.env

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

