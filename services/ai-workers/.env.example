# L3ARN AI Workers — Railway Environment Variables
# Copy to .env for local development. Never commit .env.

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (required in production — no hardcoded fallback)
# Default for local dev: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_PROVIDER=anthropic

# AI_FALLBACK_MODEL: intentionally NOT wired (decision 2026-06-28). No code reads
# it; the retry policy (AI_MAX_RETRY_ATTEMPTS) handles transient failures. A
# provider-level fallback model can be added in compiler.ts later if needed —
# see docs backlog. Do not set this expecting it to take effect.

# Retry policy (confirmed: 3 retries hard cap — ADR-054)
AI_MAX_RETRY_ATTEMPTS=3

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Safety Admin ─────────────────────────────────────────────────────────────
# Required to call POST /api/safety/check in any deployed environment.
# Use a long random string. Keep secret.
SAFETY_ADMIN_TOKEN=dev-only-token-replace-in-prod

# ── Mission Auth ──────────────────────────────────────────────────────────────
# Required in production for POST /api/missions/compile.
# Phase 0 dev: not enforced (passes through with warning).
# Sprint 1: replace with Supabase JWT verification (ADR-031).
# Use a long random string. Keep secret.
MISSION_SERVICE_TOKEN=dev-only-token-replace-in-prod

# ── Supabase (Safety Containment — Production) ────────────────────────────────
# Required in production to wire SupabaseSafetyContainment.
# Without these, NoopSafetyContainment is used (events logged to stdout only).
# SUPABASE_URL: your Supabase project URL (same as NEXT_PUBLIC_SUPABASE_URL in apps/web)
# SUPABASE_SERVICE_ROLE_KEY: service role key — NEVER the anon key.
#   Keep secret. Never commit. Set in Railway environment variables.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Founder Alerts (Phase 2 — not yet wired) ──────────────────────────────────
# Email address to notify when S3/S4 safety containment is triggered.
# Phase 2: wire to email service (SendGrid, Postmark, etc.) in SupabaseSafetyContainment.
# Phase 1: env var documented here for forward-compatibility; not yet consumed.
FOUNDER_ALERT_EMAIL=cameron@themodernblackfamily.com
